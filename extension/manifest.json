{
  "manifest_version": 3,
  "name": "hstry sync",
  "version": "0.3.2",
  "description": "Background-syncs web conversations from ChatGPT, Claude, Gemini, and Perplexity into a local hstry database.",
  "permissions": ["alarms", "storage"],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://claude.ai/*",
    "https://gemini.google.com/*",
    "https://www.perplexity.ai/*",
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "options_page": "options.html",
  "action": {
    "default_title": "hstry sync",
    "default_popup": "popup.html"
  }
}
